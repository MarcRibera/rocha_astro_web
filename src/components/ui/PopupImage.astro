---
import { Image } from 'astro:assets'

interface Props {
  src: string | ImageMetadata
  alt: string
  rememberClose?: boolean
  startDate: string
  endDate: string
}

const {
  src,
  alt,
  rememberClose = false,
  startDate,
  endDate,
} = Astro.props

const modalId = `auto-popup-${Math.random().toString(36).slice(2, 9)}`
const closeButtonId = `${modalId}-close`
const contentId = `${modalId}-content`
const storageKey = `${modalId}-closed`
---

<dialog
  id={modalId}
  class="m-0 h-screen w-screen max-w-none border-0 bg-transparent p-0 backdrop:bg-black/0"
>
  <div class="flex min-h-screen items-center justify-center px-4 py-8">
    <div
      id={contentId}
      class="relative inline-block scale-95 opacity-0 transition duration-300 ease-out"
    >
      <button
        id={closeButtonId}
        type="button"
        class="absolute right-2 top-2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/60 text-white transition hover:bg-black/80"
        aria-label="Tancar popup"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>

      {
        typeof src === 'string' ? (
          <img
            src={src}
            alt={alt}
            class="block h-auto max-h-[calc(100vh-4rem)] w-auto max-w-[calc(100vw-2rem)]"
            loading="lazy"
          />
        ) : (
          <Image
            src={src}
            alt={alt}
            class="block h-auto max-h-[calc(100vh-4rem)] w-auto max-w-[calc(100vw-2rem)]"
          />
        )
      }
    </div>
  </div>
</dialog>

<script define:vars={{ modalId, closeButtonId, contentId, storageKey, rememberClose, startDate, endDate }}>
  const modal = document.getElementById(modalId)
  const closeButton = document.getElementById(closeButtonId)
  const content = document.getElementById(contentId)

  if (
    modal instanceof HTMLDialogElement &&
    closeButton instanceof HTMLButtonElement &&
    content instanceof HTMLElement
  ) {
    const isClosed = rememberClose && localStorage.getItem(storageKey) === 'true'
    let isClosing = false

    const now = new Date()
    const start = new Date(startDate)
    const end = new Date(endDate)

    const isWithinDateRange = now >= start && now <= end

    const openModal = () => {
      modal.showModal()
      document.body.classList.add('overflow-hidden')

      modal.classList.remove('backdrop:bg-black/0')
      modal.classList.add('backdrop:bg-black/70')

      requestAnimationFrame(() => {
        content.classList.remove('scale-95', 'opacity-0')
        content.classList.add('scale-100', 'opacity-100')
      })
    }

    const closeModal = () => {
      if (isClosing) return
      isClosing = true

      modal.classList.remove('backdrop:bg-black/70')
      modal.classList.add('backdrop:bg-black/0')

      content.classList.remove('scale-100', 'opacity-100')
      content.classList.add('scale-95', 'opacity-0')

      setTimeout(() => {
        modal.close()
        isClosing = false
      }, 300)
    }

    if (isWithinDateRange && !isClosed) {
      openModal()
    }

    closeButton.addEventListener('click', closeModal)

    modal.addEventListener('close', () => {
      document.body.classList.remove('overflow-hidden')

      if (rememberClose) {
        localStorage.setItem(storageKey, 'true')
      }
    })

    modal.addEventListener('click', (event) => {
      if (!content.contains(event.target)) {
        closeModal()
      }
    })

    modal.addEventListener('cancel', (event) => {
      event.preventDefault()
      closeModal()
    })
  }
</script>